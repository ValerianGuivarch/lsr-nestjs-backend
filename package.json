{
  "name": "auth-sample",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "checkdeps": "ncu",
    "checkdeps:apply": "ncu -u",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start --entryFile main/main",
    "help": "npm run launch -- --help",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main/main.js",
    "dev:backend": "nest start --watch --entryFile main/main-unified",
    "dev:frontend": "npm run dev:web:l7r",
    "dev": "bash -c 'trap \"kill 0\" SIGINT SIGTERM EXIT; npm run dev:backend & npm run dev:frontend & wait'",
    "launch": "node scripts/launch-dev.mjs",
    "launch:config": "node scripts/launch-dev.mjs --config",
    "launch:reconfigure": "node scripts/launch-dev.mjs --config",
    "launch:list": "node scripts/launch-dev.mjs --list",
    "launch:full": "node scripts/launch-dev.mjs --profile full",
    "launch:ghost": "node scripts/launch-dev.mjs --profile ghost",
    "launch:legacy-ghost": "node scripts/launch-dev.mjs --profile legacyGhost",
    "dev:hp": "HP_PORT=3001 nest start --watch --entryFile main/main-hp",
    "dev:l7r": "L7R_PORT=3000 nest start --watch --entryFile main/main-l7r",
    "dev:yeardiary": "nest start --watch --entryFile main/main-yeardiary",
    "dev:web:l7r": "vite --config apps/web-l7r/vite.config.mts --host 0.0.0.0 --port 4200 --strictPort",
    "build:web:l7r": "vite build --config apps/web-l7r/vite.config.mts",
    "preview:web:l7r": "vite preview --config apps/web-l7r/vite.config.mts --host 0.0.0.0 --port 4200 --strictPort",
    "serve:web:l7r:nginx": "HOST=127.0.0.1 PORT=3000 WEB_ROOT=dist/apps/web-l7r node scripts/serve-web-l7r.mjs",
    "dev:web:jdr": "vite --config apps/web-jdr/vite.config.mts --host 0.0.0.0 --port 4202 --strictPort",
    "build:web:jdr": "vite build --config apps/web-jdr/vite.config.mts",
    "preview:web:jdr": "vite preview --config apps/web-jdr/vite.config.mts --host 0.0.0.0 --port 4202 --strictPort",
    "dev:jdr": "bash -c 'trap \"kill 0\" SIGINT SIGTERM EXIT; JDR_PORT=3333 ./node_modules/.bin/nx serve api-jdr & npm run dev:web:jdr & wait'",
    "dev:all": "bash -c 'trap \"kill 0\" SIGINT SIGTERM EXIT; npm run start & npm run dev:yeardiary & npm run dev:web:l7r & wait'",
    "prod:yeardiary": "node dist/src/main/main-yeardiary.js",
    "prod:all": "bash -c 'trap \"kill 0\" SIGINT SIGTERM EXIT; npm run start:prod & (npm run build:web:l7r && npm run preview:web:l7r) & wait'",
    "prod:all:nginx": "bash -c 'npm run stop:ports; trap \"kill 0\" SIGINT SIGTERM EXIT; npm run start:prod & npm run prod:yeardiary & (npm run build:web:l7r && npm run serve:web:l7r:nginx) & wait'",
    "stop:ports": "bash -c 'for p in 3000 4200 4202 8080 8081; do lsof -ti tcp:$p | xargs -r kill -9; done'",
    "dev:ghost:api": "GHOST_PORT=3100 nest start --watch --entryFile main/main-ghost",
    "dev:ghost:dashboard": "vite --config apps/web-ghost-dashboard/vite.config.mts --host 0.0.0.0 --port 4400 --strictPort",
    "dev:ghost:player": "vite --config apps/web-ghost-player/vite.config.mts --host 0.0.0.0 --port 4500 --strictPort",
    "dev:ghost": "bash -c 'trap \"kill 0\" SIGINT SIGTERM EXIT; npm run dev:ghost:api & npm run dev:ghost:dashboard & npm run dev:ghost:player & wait'",
    "start:ghost:api": "npm run dev:ghost:api",
    "start:ghost:dashboard": "npm run dev:ghost:dashboard",
    "start:ghost:player": "npm run dev:ghost:player",
    "start:ghost": "npm run dev:ghost",
    "lint": "eslint '{src,apps,libs,test}/**/*.ts' --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config src/test/e2e/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^6.10.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@nestjs/cache-manager": "^2.1.0",
    "@nestjs/common": "9.4.0",
    "@nestjs/config": "^2.3.1",
    "@nestjs/core": "9.4.0",
    "@nestjs/jwt": "10.0.3",
    "@nestjs/passport": "9.0.3",
    "@nestjs/platform-express": "^9.4.0",
    "@nestjs/platform-fastify": "^9.4.0",
    "@nestjs/platform-socket.io": "^9.4.2",
    "@nestjs/swagger": "6.3.0",
    "@nestjs/typeorm": "^9.0.1",
    "@nestjs/websockets": "^9.4.2",
    "@prismicio/client": "^7.1.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/jsdom": "^21.1.1",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "chai": "^4.3.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "fluent-json-schema": "^4.1.0",
    "js-yaml": "^4.1.0",
    "jsdom": "^22.1.0",
    "mongoose": "^7.0.3",
    "mongoose-paginate-v2": "^1.7.1",
    "multer": "^2.0.2",
    "npm-check-updates": "^16.10.7",
    "pg": "^8.10.0",
    "pino": "^8.11.0",
    "react": "^19.2.5",
    "react-bootstrap-icons": "^1.11.6",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-modal": "^3.16.3",
    "react-quill": "^2.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.2",
    "reflect-metadata": "0.1.13",
    "rimraf": "4.4.1",
    "rxjs": "7.8.0",
    "sharp": "^0.34.5",
    "socket.io-client": "^4.8.3",
    "sqlite3": "^5.1.7",
    "styled-components": "^6.4.1",
    "tslib": "^2.3.0",
    "twilio": "^4.7.2",
    "typeorm": "^0.3.29",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@darraghor/eslint-plugin-nestjs-typed": "^3.19.0",
    "@nestjs/cli": "9.3.0",
    "@nestjs/schematics": "9.1.0",
    "@nestjs/testing": "9.4.0",
    "@nx/docker": "22.7.1",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "^22.7.1",
    "@nx/nest": "^22.7.1",
    "@nx/node": "22.7.1",
    "@nx/react": "^22.7.1",
    "@nx/vite": "^22.7.1",
    "@nx/web": "22.7.1",
    "@nx/webpack": "22.7.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@tsconfig/node16": "^1.0.3",
    "@types/bcrypt": "^5.0.0",
    "@types/chance": "^1.1.3",
    "@types/ejs": "^3.1.2",
    "@types/express": "^4.17.17",
    "@types/fastify-multipart": "^0.7.0",
    "@types/jest": "29.5.0",
    "@types/js-yaml": "^4.0.5",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "20.19.9",
    "@types/qs": "^6.9.7",
    "@types/supertest": "2.0.12",
    "@types/uuid": "^9.0.1",
    "@typescript-eslint/eslint-plugin": "5.57.1",
    "@typescript-eslint/parser": "5.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "~4.1.0",
    "chance": "^1.1.11",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-import-resolver-typescript": "^3.5.5",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^2.0.0",
    "husky": "8.0.3",
    "is-ci": "^3.0.1",
    "jest": "29.5.0",
    "jest-environment-node": "^29.7.0",
    "jest-sonar-reporter": "^2.0.0",
    "jest-util": "^29.7.0",
    "jest-when": "^3.5.2",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "lint-staged": "^13.2.1",
    "nodemon": "^2.0.22",
    "npm-check-updates": "^16.10.7",
    "nx": "22.7.1",
    "prettier": "~3.6.2",
    "prettier-package-json": "^2.8.0",
    "sonarqube-scanner": "^3.0.1",
    "supertest": "6.3.3",
    "testcontainers": "^9.4.0",
    "ts-jest": "29.1.0",
    "ts-loader": "9.4.2",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.2.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.10",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "jestSonar": {
    "sonar56x": true,
    "reportPath": "coverage",
    "reportFile": "test-report.xml",
    "indent": 2
  },
  "lint-staged": {
    "*.(js|ts)": "eslint --fix",
    "*.ts": "prettier --config .prettierrc.json --write src/**/*.ts",
    "package.json": [
      "prettier-package-json --write package.json .eslintrc.json .ncurc.json .prettierrc.json",
      "git add"
    ]
  },
  "nx": {}
}
